# Conexão com Neon Postgres (com pooler HTTP — usada em runtime/API routes)
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# Conexão sem pooler (usada para migrations via drizzle-kit)
DATABASE_URL_UNPOOLED=postgres://user:password@host.neon.tech/dbname?sslmode=require

# Flag client-side: se "true", o app usa API routes (Neon). Se ausente, usa IndexedDB local.
NEXT_PUBLIC_USE_NEON=true
