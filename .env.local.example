# ─── Neon Postgres / Vercel ───────────────────────────────────────────
# Runtime (API routes) — preferir connection string COM pooler
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Migrations (drizzle-kit) — connection string SEM pooler
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require

# Aliases opcionais (templates Vercel/Neon; o app também aceita POSTGRES_URL)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# true = cliente usa /api/* → Neon | ausente/false = IndexedDB local (demo)
NEXT_PUBLIC_USE_NEON=true

# Login do painel — preferência: tabela `usuarios` no Neon (npm run db:seed-admin)
ADMIN_EMAIL=admin@seplan.ac.gov.br
ADMIN_PASSWORD=Admin@SEPLAN2026
ADMIN_NAME=Administrador SEPLAN

# Segredo para assinar cookie de sessão (recomendado em produção)
AUTH_SECRET=altere-este-segredo-em-producao

# Fallback opcional (só se a tabela usuarios estiver vazia/indisponível)
AUTH_EMAIL=
AUTH_PASSWORD=
AUTH_NAME=
